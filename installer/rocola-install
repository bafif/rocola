#!/bin/bash
# rocola-install — instalador guiado: clona el SO de la rocola al disco interno.
#
# Disparo MANUAL (desde el menú de la rocola o por consola). NUNCA formatea sin
# selección + confirmación explícita del usuario. TUI con whiptail (navegable con
# los controles de arcade / teclado).
#
# Estrategia de clonado: rsync del sistema en vivo (/) al disco destino, excluyendo
# dirs volátiles y la propia media de instalación. Particiona ESP + ROOT + DATOS(/music).
#
# NOTA: validar en QEMU/hardware antes de usar en discos con datos reales.
set -euo pipefail

TITLE="Rocola — Instalador"
LOG=/tmp/rocola-install.log
exec 3>>"$LOG"

# Modo desatendido (para QEMU/CI/factory): si ROCOLA_UNATTENDED=1 se saltan TODOS
# los prompts de whiptail y se leen las respuestas de variables de entorno:
#   ROCOLA_TARGET=/dev/sdb         (obligatoria)
#   ROCOLA_KEEP_MUSIC=yes|no       (default no)
#   ROCOLA_DISPLAY=auto|vga|crt15  (default auto)
# Nunca se usa en producción: el menú de la rocola lanza el flujo interactivo.
UNATTENDED="${ROCOLA_UNATTENDED:-0}"

die() {
    if [ "$UNATTENDED" = 1 ]; then echo "ERROR: $*  (ver $LOG)" >&2
    else whiptail --title "$TITLE" --msgbox "ERROR: $*\n\nVer $LOG" 12 70 || true; fi
    exit 1
}
log() { echo "[$(date +%T)] $*" >&3; }

[ "$(id -u)" -eq 0 ] || exec sudo -- "$0" "$@"
[ "$UNATTENDED" = 1 ] || command -v whiptail >/dev/null || die "falta whiptail"

# --- Detectar la media de instalación (para excluirla del destino) -----------
LIVE_SRC="$(findmnt -n -o SOURCE /run/live/medium 2>/dev/null || true)"
LIVE_DISK=""
if [ -n "$LIVE_SRC" ]; then
    LIVE_DISK="/dev/$(lsblk -no PKNAME "$LIVE_SRC" 2>/dev/null | head -1)"
fi
log "Media live: ${LIVE_SRC:-?} (disco ${LIVE_DISK:-?})"

# --- Selección de destino y opciones -----------------------------------------
if [ "$UNATTENDED" = 1 ]; then
    # Desatendido: todo viene de variables de entorno, sin TUI.
    TARGET="${ROCOLA_TARGET:?ROCOLA_TARGET requerido en modo desatendido}"
    [ -b "$TARGET" ] || die "ROCOLA_TARGET=$TARGET no es un dispositivo de bloque"
    [ "$TARGET" = "$LIVE_DISK" ] && die "ROCOLA_TARGET es la media de instalación"
    KEEP_MUSIC="${ROCOLA_KEEP_MUSIC:-no}"
    DISP_MODE="${ROCOLA_DISPLAY:-auto}"
    log "modo desatendido: destino=$TARGET keep_music=$KEEP_MUSIC display=$DISP_MODE"
else
    # --- Listar discos candidatos --------------------------------------------
    mapfile -t DISKS < <(lsblk -dnpo NAME,TYPE | awk '$2=="disk"{print $1}')
    MENU_ITEMS=()
    for d in "${DISKS[@]}"; do
        [ "$d" = "$LIVE_DISK" ] && continue          # excluir el pendrive de instalación
        size="$(lsblk -dno SIZE "$d")"
        model="$(lsblk -dno MODEL "$d" | tr -s ' ')"
        MENU_ITEMS+=("$d" "${size}  ${model:-disco}")
    done
    [ "${#MENU_ITEMS[@]}" -gt 0 ] || die "no se encontraron discos destino (¿solo está el pendrive?)"

    TARGET="$(whiptail --title "$TITLE" --menu \
        "Elegí el disco DESTINO.\nSe BORRARÁ por completo (salvo que conserves /music)." \
        20 74 8 "${MENU_ITEMS[@]}" 3>&1 1>&2 2>&3)" || exit 0

    # --- Conservar /music existente ------------------------------------------
    KEEP_MUSIC=no
    if whiptail --title "$TITLE" --yesno \
        "¿Conservar una partición de música existente en $TARGET (si la hay)?" 10 70; then
        KEEP_MUSIC=yes
    fi

    # --- Confirmación tipográfica (anti-borrado) -----------------------------
    SUMMARY="DESTINO: $TARGET\n$(lsblk -no NAME,SIZE,FSTYPE,LABEL "$TARGET" | sed 's/^/  /')\n\nEsto DESTRUIRÁ los datos del disco."
    CONFIRM="$(whiptail --title "$TITLE — CONFIRMAR" --inputbox \
        "$SUMMARY\n\nEscribí BORRAR (en mayúsculas) para continuar:" 18 74 3>&1 1>&2 2>&3)" || exit 0
    [ "$CONFIRM" = "BORRAR" ] || die "confirmación inválida; cancelado"

    # --- Tipo de monitor (se persiste en el destino) -------------------------
    DISP_MODE="$(whiptail --title "$TITLE" --menu "Tipo de monitor de esta rocola:" 15 70 4 \
        auto  "Autodetectar (recomendado en VGA/moderno)" \
        vga   "VGA / moderno (31 kHz)" \
        crt15 "CRT de arcade / TV (15 kHz)" 3>&1 1>&2 2>&3)" || DISP_MODE=auto
fi

# =============================================================================
# A partir de acá se escribe en disco.
# =============================================================================
# Cualquier fallo de acá en adelante aborta y reporta (set -e + trap ERR). OJO:
# NO envolver el bloque en `{ ... } || die`, porque eso DESACTIVA set -e dentro
# del grupo (gotcha de bash) y los errores (grub, rsync, mkfs) pasarían como
# "éxito". Con el trap, el primer comando que falle dispara die.
trap 'die "falló la instalación (ver $LOG)"' ERR
{
log "=== Instalando en $TARGET (keep_music=$KEEP_MUSIC, display=$DISP_MODE) ==="

# Particionado: GPT con BIOS-BOOT (ef02) + ESP (FAT32) + ROOT (ext4) + DATOS
# /music (ext4). La BIOS Boot Partition es OBLIGATORIA para arrancar por BIOS
# desde GPT: GRUB embebe ahí su core.img (en GPT no hay hueco post-MBR como en
# MBR/msdos). Sin ella, grub-install i386-pc falla ("no BIOS Boot Partition").
P_BIOS="${TARGET}1"; P_ESP="${TARGET}2"; P_ROOT="${TARGET}3"; P_DATA="${TARGET}4"
# (para discos nvme/mmc las particiones llevan sufijo pN)
case "$TARGET" in *nvme*|*mmcblk*) P_BIOS="${TARGET}p1"; P_ESP="${TARGET}p2"; P_ROOT="${TARGET}p3"; P_DATA="${TARGET}p4";; esac

# ¿Hay un layout previo de rocola (ESP+ROOT+MUSIC) que podamos conservar?
KEEP_OK=no
if [ "$KEEP_MUSIC" = yes ] \
   && blkid "$P_DATA" >/dev/null 2>&1 \
   && [ "$(blkid -s LABEL -o value "$P_DATA" 2>/dev/null)" = "music" ]; then
    KEEP_OK=yes
fi

echo "Particionando $TARGET…"
log "particionando (keep_ok=$KEEP_OK)"
if [ "$KEEP_OK" = yes ]; then
    # NO reparticionar: conservar la tabla y la partición de música intactas.
    # Sólo se reformatean ESP y ROOT más abajo; DATA queda como está.
    log "conservando layout y partición de música $P_DATA"
else
    if [ "$KEEP_MUSIC" = yes ]; then
        log "no hay partición 'music' previa reconocible; se hará layout nuevo"
    fi
    sgdisk --zap-all \
        --new=1:0:+2M    --typecode=1:ef02 --change-name=1:BIOSBOOT \
        --new=2:0:+256M  --typecode=2:ef00 --change-name=2:ESP \
        --new=3:0:+12G   --typecode=3:8300 --change-name=3:ROOT \
        --new=4:0:0      --typecode=4:8300 --change-name=4:MUSIC "$TARGET" >&3 2>&1
fi
partprobe "$TARGET"; sleep 2

echo "Formateando…"; log "mkfs"
mkfs.vfat -F32 -n ESP "$P_ESP"        >&3 2>&1
mkfs.ext4 -F -L rocola-root "$P_ROOT" >&3 2>&1
if [ "$KEEP_OK" = yes ]; then
    log "conservando datos en $P_DATA (sin formatear)"
else
    mkfs.ext4 -F -L music "$P_DATA"   >&3 2>&1
fi

# Montaje del destino
T=/target; mkdir -p "$T"
mount "$P_ROOT" "$T"
mkdir -p "$T/boot/efi" "$T/music"
mount "$P_ESP" "$T/boot/efi"
mount "$P_DATA" "$T/music" || true

echo "Clonando el sistema (puede tardar)…"; log "rsync /"
rsync -aHAXx --info=progress2 \
    --exclude=/proc --exclude=/sys --exclude=/dev --exclude=/run \
    --exclude=/tmp --exclude=/mnt --exclude=/media --exclude=/target \
    --exclude=/music --exclude=/lost+found \
    --exclude=/run/live --exclude='/var/cache/apt/archives/*' \
    / "$T" >&3 2>&1

# fstab por UUID
echo "Generando fstab…"; log "fstab"
{
    echo "# generado por rocola-install"
    echo "UUID=$(blkid -s UUID -o value "$P_ROOT")  /          ext4  defaults,noatime  0 1"
    echo "UUID=$(blkid -s UUID -o value "$P_ESP")   /boot/efi  vfat  umask=0077        0 1"
    echo "UUID=$(blkid -s UUID -o value "$P_DATA")  /music     ext4  defaults,noatime  0 2"
} > "$T/etc/fstab"

# Persistir tipo de monitor
mkdir -p "$T/etc/rocola"
sed -i "s/^MODE=.*/MODE=$DISP_MODE/" "$T/etc/rocola/display.conf" 2>/dev/null \
    || echo "MODE=$DISP_MODE" > "$T/etc/rocola/display.conf"

# Bootloader. grub-install corre FUERA del chroot, con --boot-directory apuntando
# al /boot del sistema clonado: así grub-probe resuelve el disco destino con el
# /proc/mounts real del sistema vivo. (Dentro de un chroot, /proc/mounts no mapea
# el destino -> el error típico "cannot find a device for /boot/grub".)
echo "Instalando GRUB (BIOS + UEFI)…"; log "grub"
grub-install --target=i386-pc --boot-directory="$T/boot" --recheck "$TARGET" >&3 2>&1
grub-install --target=x86_64-efi --efi-directory="$T/boot/efi" \
    --boot-directory="$T/boot" --bootloader-id=rocola --removable --recheck >&3 2>&1

# grub.cfg del sistema instalado: en chroot, para que grub-mkconfig detecte el
# kernel y el root=UUID del DESTINO (no los del medio vivo). Necesita /proc,/sys,
# /dev,/run montados dentro del chroot. OJO: el rsync excluye esas rutas, así que
# los puntos de montaje pueden no existir en el destino -> hay que crearlos
# (si no, el bind falla y grub corre sin /dev: "is /dev mounted?").
for fs in proc sys dev dev/pts run; do mkdir -p "$T/$fs"; mount --bind "/$fs" "$T/$fs"; done
chroot "$T" /usr/sbin/update-grub >&3 2>&1

# Desmontar
echo "Finalizando…"; log "umount"
for fs in run dev/pts dev sys proc; do umount "$T/$fs" || true; done
umount "$T/music" 2>/dev/null || true
umount "$T/boot/efi"; umount "$T"
log "OK"
} 2>&3
trap - ERR   # a partir de acá los prompts pueden devolver no-cero sin abortar

if [ "$UNATTENDED" = 1 ]; then
    echo "Instalación desatendida completa en $TARGET."
    exit 0
fi

if whiptail --title "$TITLE" --yesno \
    "¡Instalación completa!\n\nQuitá el pendrive y reiniciá.\n\n¿Reiniciar ahora?" 12 60; then
    systemctl reboot
fi
