# Permite que Xorg, lanzado por rocola.service como el usuario 'rocola' (no root,
# y sin una sesión de consola "clásica"), pueda abrir la VT / KMS.
#
# Sin esto, Xorg suele fallar con:
#   (EE) xf86OpenConsole: Cannot open virtual console 1 (Permission denied)
#
# 'needs_root_rights=yes' hace que el wrapper setuid (Xorg.wrap, de
# xserver-xorg-legacy) arranque Xorg con privilegios suficientes para tomar la VT.
allowed_users=anybody
needs_root_rights=yes
