#!/bin/bash
# rocola-display-setup — configura el video de la rocola según el tipo de monitor.
#
# Lo corre un servicio oneshot ANTES de arrancar Xorg/la UI. Como X todavía no
# está corriendo, NO usa xrandr: genera un snippet de Xorg con los modelines
# adecuados (VGA/moderno por EDID, o CRT 15 kHz con modelines fijos).
#
# Lee /etc/rocola/display.conf (MODE = auto|vga|crt15). Ver docs/05.
set -euo pipefail

CONF=/etc/rocola/display.conf
MODELINES_DIR=/opt/rocola-display/modelines
OUT=/etc/X11/xorg.conf.d/10-rocola-display.conf

MODE=auto
TV_STANDARD=ntsc
PREFERRED_RES=
# shellcheck disable=SC1090
[ -f "$CONF" ] && . "$CONF" || true

mkdir -p /etc/X11/xorg.conf.d 2>/dev/null || true

# Defensa en profundidad (kiosko): si /etc no es escribible —no debería pasar, el
# servicio ya corre con el rootfs rw (After=local-fs.target)— NO abortamos el
# arranque. Sin esta config Xorg autodetecta por EDID y la UI igual abre; preferimos
# eso a dejar la rocola en una consola de texto por un fallo de escritura.
if ! ( : >> "$OUT" ) 2>/dev/null; then
    echo "rocola-display-setup: no puedo escribir $OUT (¿/etc read-only?); Xorg autodetectará" >&2
    exit 0
fi

# Elige el driver de Xorg según haya o no KMS. CLAVE para no crashear:
#  - Con KMS (/dev/dri/card0 presente): 'modesetting' (genérico; sirve para los
#    modelines de CRT 15 kHz y para GPUs cuyo KMS funciona).
#  - Sin KMS (arranque con 'nomodeset', o el kernel i386 no soporta la GPU):
#    'fbdev' sobre el framebuffer del firmware (efifb en UEFI, vesafb en BIOS).
#    NO dejamos que Xorg autodetecte, porque puede elegir 'vesa', que **se niega a
#    correr bajo UEFI** ("Refusing to run on UEFI") y tumba el servidor X.
detect_driver() {
    if [ -e /dev/dri/card0 ]; then echo modesetting; else echo fbdev; fi
}

device_section() {
    local drv; drv="$(detect_driver)"
    echo 'Section "Device"'
    echo '    Identifier "rocola-gpu"'
    printf '    Driver "%s"\n' "$drv"
    # Con fbdev, apuntar al framebuffer explícitamente: sin esto el driver a veces
    # tira "Unable to find a valid framebuffer device" sobre efifb y crashea X.
    [ "$drv" = fbdev ] && echo '    Option "fbdev" "/dev/fb0"'
    echo 'EndSection'
    echo "rocola-display-setup: driver de video = $drv $( [ -e /dev/dri/card0 ] && echo '(KMS)' || echo '(sin KMS -> fbdev)')" >&2
}

write_vga() {
    {
        echo "# VGA / moderno. Driver forzado (ver detect_driver); Xorg toma los modos por EDID."
        device_section
        echo 'Section "Monitor"'
        echo '    Identifier "rocola-vga"'
        echo 'EndSection'
    } > "$OUT"
}

write_crt15() {
    local pref="${PREFERRED_RES:-640x480i_60}"
    {
        echo "# CRT 15 kHz — generado por rocola-display-setup (ajustar por monitor)."
        echo "# El 15 kHz requiere KMS: arrancá la entrada de GRUB 'aceleración GPU / CRT 15 kHz'."
        device_section
        echo 'Section "Monitor"'
        echo '    Identifier "rocola-crt15"'
        echo '    HorizSync 15.0-16.5'
        echo '    VertRefresh 49-61'
        if [ -f "$MODELINES_DIR/15khz.conf" ]; then
            grep -h '^[[:space:]]*Modeline' "$MODELINES_DIR/15khz.conf" || true
        fi
        echo "    Option \"PreferredMode\" \"$pref\""
        echo 'EndSection'
    } > "$OUT"
}

case "$MODE" in
    crt15)
        write_crt15
        ;;
    vga)
        write_vga
        ;;
    auto | *)
        # Autodetección. Los CRT de 15 kHz NO entregan EDID confiable, así que
        # 'auto' siempre escribe una config VGA segura (Xorg elige el mejor modo
        # por EDID si lo hay). El 15 kHz se activa explícitamente con MODE=crt15.
        # El chequeo de EDID sólo sirve para dejar una pista útil en el log.
        write_vga
        if command -v get-edid >/dev/null 2>&1 \
           && get-edid 2>/dev/null | parse-edid 2>/dev/null | grep -qi 'Modeline\|Monitor'; then
            echo "rocola-display-setup: EDID detectado -> modos VGA/moderno por EDID"
        else
            echo "rocola-display-setup: sin EDID útil; VGA seguro. Si usás CRT 15 kHz, poné MODE=crt15 en $CONF"
        fi
        ;;
esac

echo "rocola-display-setup: MODE=$MODE TV=$TV_STANDARD -> $OUT"
